# ───────────────────────────────────────────────────────────────────────────
# vltUSDC vault — Hardhat environment
# Copy to `.env` and fill in. NEVER commit the real .env (it is gitignored).
# ───────────────────────────────────────────────────────────────────────────

# --- RPC endpoints (archive node recommended for forking) ---
MAINNET_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY

# Pin the fork to a recent block. STRONGLY recommended — unpinned ("latest") forking can return
# intermittent 403s from some RPCs (e.g. Alchemy) and disables the local cache. Any recent block.
FORK_BLOCK_NUMBER=25217000

# Leave BLANK. The fork suite enables forking itself via `npm run test:fork` (FORK=1 inline).
# Setting FORK=1 here would make EVERY `npm test` run fork the local suite (slow + needs the RPC).
FORK=

# --- One-shot fork setup for the browser test client (npm run fork:node + npm run fork:setup) ---
# Your wallet's address. `npm run fork:setup` funds it (ETH + USDC) and sets it as the vault
# owner, so you connect your existing wallet on the fork with NO private-key import. If blank,
# the deployer (hardhat account #0) is funded/owned instead.
DEV_ACCOUNT=
# Amounts fork:setup grants DEV_ACCOUNT (defaults shown).
FUND_ETH=1000
FUND_USDC=1000000

# --- zaphelper.fork.test.js knobs (optional) ---
# Output token + USDC-in for the real Universal Router zap. Defaults: WETH, 10000 USDC.
ZAP_TEST_TOKEN_OUT=
ZAP_TEST_V3_FEE=500
ZAP_TEST_USDC_IN=
# The built-in encoder only does a SINGLE-HOP V3 USDC->token swap (fine for WETH). VLT has no V3
# pool (it's V2 VLT/WETH only), so to test USDC->VLT paste a full Universal Router route here from
# the Uniswap Routing API (USDC->WETH via V3, WETH->VLT via V2). Set its output recipient to the
# UR MSG_SENDER constant (0x0000000000000000000000000000000000000001) so it's helper-independent,
# and set ZAP_TEST_TOKEN_OUT=<VLT> so the test measures VLT received.
ZAP_TEST_SWAPDATA=

# --- Deployer key (use a dedicated, funded throwaway/hardware-backed key) ---
# Either a raw private key OR a mnemonic. Private key takes precedence.
DEPLOYER_PRIVATE_KEY=
# MNEMONIC="test test test test test test test test test test test junk"

# --- Etherscan verification ---
ETHERSCAN_API_KEY=

# --- Deployment parameters (override the mainnet defaults in scripts/config) ---
# Uniswap V4 PoolManager. Defaults to the Ethereum-mainnet singleton if unset.
POOL_MANAGER_ADDRESS=
# VLT and USDC token addresses on the target chain.
VLT_ADDRESS=
USDC_ADDRESS=
# Pool params. Fee in hundredths-of-a-bip (1% = 10000). Tick spacing for 1% = 200.
POOL_FEE=10000
TICK_SPACING=200
# Initial pool price as USDC-per-VLT (e.g. 0.5) OR a raw sqrtPriceX96 (sqrt wins).
# Only used when this tooling CREATES the pool (00_create_and_init_pool.js).
INIT_USDC_PER_VLT=
INIT_SQRT_PRICE_X96=

# Vault owner (pause/sweep authority). Defaults to the deployer if unset.
VAULT_OWNER=

# Address of an already-deployed vault (set after 01_deploy_vault.js; used by deploy_zaphelper /
# seed / verify).
VAULT_ADDRESS=

# --- Periphery ZapHelper (deploy_zaphelper.js, run AFTER the vault) ---
# Swap router the helper executes routes against. Defaults to the mainnet Universal Router.
ZAP_ROUTER_ADDRESS=
# Permit2. Defaults to canonical (0x000000000022D473030F116dDEE9F6B43aC78BA3).
# Set to 0x0000000000000000000000000000000000000000 only for a plain-allowance router.
ZAP_PERMIT2_ADDRESS=
# Deployed ZapHelper address (set after running deploy_zaphelper.js). Verify-only.
ZAP_HELPER_ADDRESS=

# First-deposit seeding (02_seed_first_deposit.js) — a direct balanced pair (no routing).
SEED_USDC=
SEED_VLT=
